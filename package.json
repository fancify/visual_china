{
  "name": "qianli-jiangshan",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:dem": "node scripts/build-qinling-real-dem.mjs && node scripts/build-qinling-region-assets.mjs",
    "build:routes": "node scripts/build-shu-road-paths.mjs",
    "build:poi-registry": "node scripts/build-poi-registry.mjs",
    "build:qinling:region": "node scripts/build-qinling-region-assets.mjs",
    "qinling:fabdem:download": "node scripts/download-qinling-fabdem.mjs",
    "qinling:fabdem:extract": "node scripts/extract-qinling-fabdem.mjs",
    "qinling:dem:status": "node scripts/qinling-dem-status.mjs",
    "qinling:dem:build-real": "node scripts/build-qinling-real-dem.mjs && node scripts/build-qinling-region-assets.mjs && node scripts/build-qinling-route-anchors.mjs && node scripts/build-shu-road-paths.mjs",
    "build:hydrography:report": "node scripts/build-qinling-hydrography-report.mjs",
    "fetch:hydrography:osm": "node scripts/fetch-qinling-osm-waterways.mjs",
    "build:hydrography:osm": "node scripts/build-qinling-osm-hydrography.mjs",
    "build:hydrography:primary": "node scripts/build-qinling-primary-hydrography.mjs",
    "verify:dem": "node scripts/verify-dem-assets.mjs public/data/qinling-slice-dem.json public/data/regions/qinling/manifest.json",
    "verify:hydrography": "node scripts/build-qinling-hydrography-report.mjs && node --test scripts/hydrography-dem-validation.test.mjs scripts/qinling-hydrography-report.test.mjs",
    "test:fast": "node scripts/test-groups.mjs fast",
    "test:visual": "node scripts/test-groups.mjs visual",
    "test:data": "node scripts/test-groups.mjs data",
    "test:audio": "node scripts/test-groups.mjs audio",
    "test:ci": "npm run typecheck && node scripts/test-groups.mjs ci",
    "test": "node scripts/test-groups.mjs all",
    "china:fabdem:download": "node scripts/download-china-fabdem.mjs",
    "china:fabdem:extract": "node scripts/extract-china-fabdem.mjs",
    "china:dem:build": "node scripts/build-china-national-dem.mjs",
    "china:lowres:download": "node scripts/download-china-lowres-etopo.mjs",
    "china:lowres:build": "node scripts/build-china-lowres-dem.mjs",
    "build:land-mask": "node scripts/build-china-land-mask-gshhg.mjs",
    "regression:baseline": "node --test scripts/regression-baseline.test.mjs",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run test:fast",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "geotiff": "^3.0.5",
    "three": "^0.178.0"
  },
  "devDependencies": {
    "@types/three": "^0.178.1",
    "shapefile": "^0.6.6",
    "shpjs": "^6.2.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.0"
  }
}
